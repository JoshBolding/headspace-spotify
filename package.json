{
  "name": "headspace-spotify",
  "version": "0.0.1",
  "description": "Headspace skin reborn as a Spotify client — alien-head music player with library browsing, beat-synced visuals, and modern features.",
  "main": "dist-main/main.js",
  "scripts": {
    "dev:main": "tsc -p tsconfig.main.json --watch",
    "dev:renderer": "vite",
    "build:main": "tsc -p tsconfig.main.json",
    "build:renderer": "vite build",
    "build": "npm run build:main && npm run build:renderer",
    "start": "npm run build && electron .",
    "electron:dev": "npm run build:main && electron ."
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "electron": "github:castlabs/electron-releases#v41.1.1+wvcus",
    "typescript": "^5.6.0",
    "vite": "^5.4.0"
  },
  "dependencies": {
    "music-metadata": "^11.12.3"
  }
}
